# Veritabani baglanti bilgileri
# v1.1 (V11-106/K14): DB user ayrimi — iki ayri PG user.
#   CUSTOS_DB_DSN        → runtime (custos_app, sadece DML)
#   CUSTOS_DB_ADMIN_DSN  → migration / DDL owner (custos_admin)
# Bu iki DSN tanimliysa POSTGRES_* asagisi yok sayilir.
# Yeni kurulumlarda setup.sh otomatik uretir; geriye donuk uyum icin
# eski POSTGRES_* alanlari korunur (lokal/dev tek-user).
# CUSTOS_DB_DSN=postgresql://custos_app:DEGISTIRRSIRR@localhost:5432/custos
# CUSTOS_DB_ADMIN_DSN=postgresql://custos_admin:DEGISTIRRSIRR@localhost:5432/custos

# Eski (legacy) tek-user yapisi — CUSTOS_DB_* tanimli degilse kullanilir.
POSTGRES_DB=custos
POSTGRES_USER=custos
POSTGRES_PASSWORD=degistir-bu-bir-ornektir
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Uygulama log seviyesi
LOG_LEVEL=INFO

# VAPID push bildirim ayarlari
# generate_vapid_keys.py ile uretilir
CUSTOS_VAPID_PRIVATE_KEY=
CUSTOS_VAPID_PUBLIC_KEY=
CUSTOS_VAPID_MAILTO=mailto:admin@custos.local

# Sessiz saat hesabi icin yerel zaman dilimi (IANA formati)
CUSTOS_TIMEZONE=Europe/Istanbul

# TLS reverse proxy (V11-102 / P-03) — Caddy bu IP'de TLS sonlandiracak.
# Pilot mini PC'ye IT'nin atadigi statik LAN IP. Setup.sh boş ise hostname -I
# tahminini yazar; manuel set etmek tercih edilir.
# CUSTOS_HOST_IP=192.168.1.10

# Geliştirme escape hatch: HTTPS olmadan calisirken cookie Secure flag'i kapansin
# (lokal `python -m custos.analytics` icin). Pilot deploy'da set EDILMEZ.
# CUSTOS_DEV_INSECURE_COOKIE=1

# Collector paralel okuma ayarlari (F11 Paket G).
# per_host_concurrency: tek Modbus slave'e ayni anda en fazla kac paralel okuma.
# fast_polling_budget: polling_interval_ms <= 1000 olan aktif tag sayisi siniri.
# Pilot 200 tag gercegi icin default 60 (v1.0.1 kalem 17). v1.1'de threshold
# semantigi (1000ms "fast" sayilmali mi?) yeniden degerlendirilecek.
# COLLECTOR_PER_HOST_CONCURRENCY=5
COLLECTOR_FAST_POLLING_BUDGET=60

# Gelistirme modu (showcase sayfasini aktif eder)
# CUSTOS_DEV_MODE=true

# Teknik asistan chatbot (F8b) ayarlari.
# knowledge_dir: Bilgi tabani kok dizini (markdown + yaml). Default: data/knowledge
# score_threshold: Semantic search min cosine benzerlik (0.0-1.0). Altinda "bulamadim".
# top_k: Semantic search'te donen en yakin chunk sayisi.
# CUSTOS_ASSISTANT_KNOWLEDGE_DIR=data/knowledge
# CUSTOS_ASSISTANT_SCORE_THRESHOLD=0.35
# CUSTOS_ASSISTANT_TOP_K=3

# HuggingFace model cache dizini. Operator internetsiz kurulum icin
# modeli onceden indirip bu yolu ayarlayabilir; default davranis HF varsayilani.
# HF_HOME=/var/custos/hf_cache
