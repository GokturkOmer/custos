[Unit]
Description=Custos Endustriyel Edge Izleme Sistemi
After=network.target postgresql.service

[Service]
Type=simple
User=custos
WorkingDirectory=/opt/custos
EnvironmentFile=/opt/custos/.env
ExecStart=/opt/custos/.venv/bin/uvicorn custos.__main__:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
